    <script>
        /* explore.js — paste before </body> in your explore EJS */

document.addEventListener('DOMContentLoaded', function () {

  // ── Staggered reveal for course sections ─────────────────
  const sections = document.querySelectorAll('.course-feature');
  const finalCta = document.querySelector('.explore-final');

  const observer = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        entry.target.classList.add('visible');
        entry.target.style.transition =
          `opacity 0.75s cubic-bezier(0.4,0,0.2,1) ${entry.target.dataset.delay || 0}ms,
           transform 0.75s cubic-bezier(0.4,0,0.2,1) ${entry.target.dataset.delay || 0}ms`;
        observer.unobserve(entry.target);
      }
    });
  }, { threshold: 0.12 });

  // Stagger each section slightly
  sections.forEach((section, i) => {
    section.dataset.delay = i * 100;
    observer.observe(section);
  });

  // Final CTA reveal
  if (finalCta) observer.observe(finalCta);

  // ── Button arrow slide on hover ───────────────────────────
  document.querySelectorAll('.feature-btn').forEach(btn => {
    const original = btn.textContent.trim();
    btn.addEventListener('mouseenter', () => {
      btn.style.letterSpacing = '0.04em';
    });
    btn.addEventListener('mouseleave', () => {
      btn.style.letterSpacing = '0.01em';
    });
  });

});
    </script>