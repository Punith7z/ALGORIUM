<% layout("/layouts/boilerplate.ejs" )%>

<div class="about-premium-page">
    <!-- Hero Section -->
    <section class="about-premium-hero">
        <div class="hero-bg-glow"></div>
        <div class="container text-center position-relative">
            <h1 class="hero-title">Experience <span class="text-gradient">Algorium</span></h1>
            <p class="hero-subtitle">A visionary learning initiative crafted by MVJ College of Engineering to shape the tech leaders of tomorrow.</p>
        </div>
    </section>

    <!-- Intro Section -->
    <section class="about-premium-intro container">
        <div class="row align-items-center g-5">
            <div class="col-lg-6">
                <div class="premium-text-box">
                    <h2 class="section-title">What is Algorium?</h2>
                    <p class="section-desc">
                        Algorium is a world-class educational platform meticulously designed to immerse students into the cutting-edge realms of <strong>Artificial Intelligence</strong>, <strong>Data Science</strong>, and <strong>Software Development</strong>.
                    </p>
                    <p class="section-desc">
                        We provide carefully curated learning paths, studio-quality lectures, and hands-on practical environments that effortlessly decode complex technological paradigms into masterable skills.
                    </p>
                    <a href="/" class="premium-btn mt-3">Explore Courses <i class="fa-solid fa-arrow-right ms-2"></i></a>
                </div>
            </div>
            <div class="col-lg-6 position-relative">
                <div class="premium-image-wrapper">
                    <img src="/images/aibrain.png" alt="AI Brain" class="premium-img float-animation">
                    <div class="image-glow"></div>
                </div>
            </div>
        </div>
    </section>

    <!-- College Section -->
    <section class="about-premium-college container">
        <div class="row align-items-center flex-column-reverse flex-lg-row g-5">
            <div class="col-lg-6 position-relative">
                <div class="premium-image-wrapper">
                    <img src="/images/mvj.webp" alt="MVJ College" class="premium-img glow-border">
                </div>
            </div>
            <div class="col-lg-6">
                <div class="premium-text-box ms-lg-4">
                    <h2 class="section-title">Powered by MVJCE</h2>
                    <p class="section-desc">
                        At MVJ College of Engineering, we have a relentless commitment to pushing the boundaries of high-quality technical education and acting as a cradle for deep innovation.
                    </p>
                    <p class="section-desc">
                        Through elite initiatives like Algorium, we empower students to effortlessly adapt to the pace of emerging technologies and forge unbreakable careers for the future.
                    </p>
                </div>
            </div>
        </div>
    </section>

    <!-- Mission Section -->
    <section class="about-premium-mission">
        <div class="container text-center">
            <div class="mission-glass-card">
                <h2 class="mission-title">Our Ultimate Mission</h2>
                <p class="mission-desc">
                    "To radically democratize top-tier education in AI, Data Science, and Software Development—fueling an unstoppable generation of innovators, creators, and limitless problem-solvers."
                </p>
            </div>
        </div>
    </section>
</div>