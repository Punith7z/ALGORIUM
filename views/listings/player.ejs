<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Algorium | Course Player</title>
  <link rel="stylesheet" href="/style1.css" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
      <link rel="icon" type="image/png" href="/images/rnlogo.png" sizes="48x48">
  <link href="https://fonts.googleapis.com/css2?family=SF+Pro+Display:wght@300;400;500;600;700&family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;0,9..40,600;1,9..40,300&display=swap" rel="stylesheet" />
  <!-- Fallback for SF Pro -->
  <link href="https://fonts.googleapis.com/css2?family=Figtree:wght@300;400;500;600;700&family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;0,9..40,600&display=swap" rel="stylesheet" />
</head>
<body>

  <!-- ═══════════════════════════════════════════════
       NAVBAR
  ═══════════════════════════════════════════════ -->
  <nav class="navbar">
    <div class="navbar-left">
      <button class="btn-go-back" onclick="goBackToCourse()">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
          <polyline points="15 18 9 12 15 6"/>
        </svg>
        Back
      </button>
      <a href="/" class="logo-link">
        <!-- Replace src with your actual logo path -->
        <img src="/images/algo.png" alt="Algorium" class="navbar-logo" />
      </a>
    </div>
    
    <div class="navbar-center">
      <span class="course-title-nav"><%= course.title %></span>
    </div>
    <div class="navbar-right">
      <a class="quiz-cta" href="/quiz/<%= topic %>">
  <span class="quiz-cta-icon">
    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
      <path d="M9 11l3 3L22 4"/>
      <path d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11"/>
    </svg>
  </span>
  <span class="quiz-cta-text">
    Take Quiz
    <small>Test your understanding</small>
  </span>
  <span class="quiz-cta-glow"></span>
</a>
  <div class="progress-pill">
    <span class="progress-label"><%= completedCount %>/<%= totalCount %> completed</span>
    <div class="progress-bar-mini">
      <div class="progress-bar-fill" style="width: <%= progressPercent %>%"></div>
    </div>

  </div>

  <% if (currentUser) { %>
    <!-- User Profile -->
    <div class="player-user-profile">
      <button class="player-user-btn" onclick="togglePlayerDropdown()">
        <div class="player-user-avatar">
          <%= currentUser.name.charAt(0).toUpperCase() %>
        </div>
        <span class="player-user-name"><%= currentUser.name.split(' ')[0] %></span>
        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="6 9 12 15 18 9"/></svg>
      </button>
      <div class="player-user-dropdown" id="player-dropdown">
        <div class="player-nui-info">
          <div class="player-nui-avatar">
            <%= currentUser.name.charAt(0).toUpperCase() %>
          </div>
          <div>
            <p class="player-nui-name"><%= currentUser.name %></p>
            <p class="player-nui-email"><%= currentUser.email %></p>
          </div>
        </div>
        <hr class="player-nui-divider">
        <a class="player-nui-item" href="/explore">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><polygon points="10 8 16 12 10 16 10 8"/></svg>
          All Courses
        </a>

        <hr class="player-nui-divider">
        <a class="player-nui-item player-nui-logout" href="/logout">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/><polyline points="16 17 21 12 16 7"/><line x1="21" y1="12" x2="9" y2="12"/></svg>
          Logout
        </a>
      </div>
    </div>
  <% } else { %>
    <button class="btn-nav-action" onclick="window.location.href='/login'">Login</button>
  <% } %>
</div>
  </nav>

  <!-- ═══════════════════════════════════════════════
       MAIN LAYOUT
  ═══════════════════════════════════════════════ -->
  <main class="player-shell">

    <!-- ── LEFT: VIDEO PLAYER COLUMN ─────────────── -->
    <section class="player-main">

      <!-- Video Embed -->
      <div class="video-wrapper">
        <div class="video-frame-border">
          <iframe
            id="yt-player"
            class="yt-iframe"
            src="https://www.youtube.com/embed/<%= currentVideo.videoId %>?enablejsapi=1&rel=0&modestbranding=1&color=white&iv_load_policy=3"
            title="<%= currentVideo.title %>"
            frameborder="0"
            allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
            allowfullscreen>
          </iframe>
        </div>
        <!-- Thin gradient accent under player -->
        <div class="player-accent-line"></div>
      </div>

      <!-- Video Meta -->
      <div class="video-meta">
        <div class="video-meta-top">
          <div class="lecture-badge">Lecture <%= currentVideo.index + 1 %></div>
          <div class="video-actions">
<a href="/pdfs/<%= topic %>.pdf" target="_blank" class="icon-btn" title="Notes">
  <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
    <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
    <polyline points="14 2 14 8 20 8"/>
    <line x1="16" y1="13" x2="8" y2="13"/>
    <line x1="16" y1="17" x2="8" y2="17"/>
  </svg>
</a>
          </div>
        </div>
        <h1 class="video-title"><%= currentVideo.title %></h1>

        <!-- Instructor row -->
        <div class="instructor-row">
          <div class="instructor-avatar">
            <img src="<%= course.instructorAvatar %>" alt="<%= course.instructor %>" />
          </div>
          <div class="instructor-info">
            <span class="instructor-name"><%= course.instructor %></span>
            <span class="instructor-role">Course Instructor</span>
          </div>

        </div>
      </div>

      <!-- Prev / Next navigation -->
      <div class="lesson-nav">
        <% if (prevVideo) { %>
        <a href="/course/<%= course.id %>/lesson/<%= prevVideo.id %>" class="lesson-nav-btn prev">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="15 18 9 12 15 6"/></svg>
          <div class="lesson-nav-text">
            <span class="lesson-nav-label">Previous</span>
            <span class="lesson-nav-title"><%= prevVideo.title %></span>
          </div>
        </a>
        <% } else { %>
        <div class="lesson-nav-btn prev disabled"></div>
        <% } %>

        <% if (nextVideo) { %>
        <a href="/course/<%= course.id %>/lesson/<%= nextVideo.id %>" class="lesson-nav-btn next">
          <div class="lesson-nav-text">
            <span class="lesson-nav-label">Next Lesson</span>
            <span class="lesson-nav-title"><%= nextVideo.title %></span>
          </div>
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="9 18 15 12 9 6"/></svg>
        </a>
        <% } %>
      </div>

    </section>

    <!-- ── RIGHT: PLAYLIST SIDEBAR ───────────────── -->
    <aside class="playlist-sidebar">

      <div class="sidebar-header">
        <h2 class="sidebar-heading">Course Content</h2>
        <span class="sidebar-count"><%= totalCount %> lessons</span>
      </div>

      <!-- Overall progress -->
      <div class="sidebar-progress">
        <div class="sidebar-progress-bar">
          <div class="sidebar-progress-fill" style="width: <%= progressPercent %>%"></div>
        </div>
        <span class="sidebar-progress-text"><%= progressPercent %>% complete</span>
      </div>

      <!-- Section filter tabs (optional sections) -->
      <div class="section-tabs">
        <% sections.forEach((section, i) => { %>
        <button
          class="section-tab <%= i === activeSectionIndex ? 'active' : '' %>"
          onclick="scrollToSection('<%= section.id %>')">
          <%= section.title %>
        </button>
        <% }) %>
      </div>

      <!-- Scrollable lesson list -->
      <div class="lessons-scroll" id="lessons-scroll">
        <% sections.forEach((section, si) => { %>

        <div class="section-group" id="section-<%= section.id %>">
          <div class="section-label">
            <span><%= section.title %></span>
            <span class="section-duration"><%= section.totalDuration %></span>
          </div>

          <% section.videos.forEach((video, vi) => { %>
          <a
            href="/course/<%= course.id %>/lesson/<%= video.id %>"
            class="lesson-item <%= video.id === currentVideo.id ? 'active' : '' %> <%= video.completed ? 'completed' : '' %>"
            data-video-id="<%= video.videoId %>">

            <!-- Thumbnail -->
            <div class="lesson-thumb-wrap">
              <img
                src="https://img.youtube.com/vi/<%= video.videoId %>/mqdefault.jpg"
                alt="<%= video.title %>"
                class="lesson-thumb"
                loading="lazy" />
              <!-- Play overlay -->
              <div class="thumb-overlay">
                <% if (video.completed) { %>
                <div class="thumb-check">
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><polyline points="20 6 9 17 4 12"/></svg>
                </div>
                <% } else if (video.id === currentVideo.id) { %>
                <div class="thumb-playing">
                  <span></span><span></span><span></span>
                </div>
                <% } else { %>
                <div class="thumb-play-icon">
                  <svg width="12" height="12" viewBox="0 0 24 24" fill="currentColor"><polygon points="5 3 19 12 5 21 5 3"/></svg>
                </div>
                <% } %>
              </div>
              <span class="lesson-duration-badge"><%= video.duration %></span>
            </div>

            <!-- Info -->
            <div class="lesson-info">
              <span class="lesson-number">
                <% if (video.completed) { %>
                <svg class="check-icon" width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><polyline points="20 6 9 17 4 12"/></svg>
                <% } else { %>
                <%= video.globalIndex + 1 %>.
                <% } %>
              </span>
              <div class="lesson-text">
                <span class="lesson-title"><%= video.title %></span>
                <span class="lesson-meta">
                  <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
                  <%= video.duration %>
                </span>
              </div>
            </div>

          </a>
          <% }) %>

        </div>
        <% }) %>
      </div><!-- /lessons-scroll -->

    </aside>

  </main>

  <!-- ═══════════════════════════════════════════════
       SCRIPTS
  ═══════════════════════════════════════════════ -->
  <script>
    // ── Auto-scroll active lesson into view ──────────
    document.addEventListener('DOMContentLoaded', () => {
      const active = document.querySelector('.lesson-item.active');
      if (active) {
        active.scrollIntoView({ behavior: 'smooth', block: 'center' });
      }
    });

    // ── Bookmark toggle ──────────────────────────────
    function toggleBookmark(btn) {
      btn.classList.toggle('bookmarked');
    }

    // ── Scroll sidebar to section ────────────────────
    function scrollToSection(id) {
      const el = document.getElementById('section-' + id);
      if (el) el.scrollIntoView({ behavior: 'smooth', block: 'start' });
      document.querySelectorAll('.section-tab').forEach(t => t.classList.remove('active'));
      event.currentTarget.classList.add('active');
    }

    // ── YT Player API: auto-advance on video end ─────
    var tag = document.createElement('script');
    tag.src = "https://www.youtube.com/iframe_api";
    document.head.appendChild(tag);

    var player;
    function onYouTubeIframeAPIReady() {
      player = new YT.Player('yt-player', {
        events: {
          'onStateChange': onPlayerStateChange
        }
      });
    }

    function onPlayerStateChange(event) {
      // YT.PlayerState.ENDED = 0
      if (event.data === 0) {
        const nextBtn = document.querySelector('.lesson-nav-btn.next');
        if (nextBtn) {
          setTimeout(() => { nextBtn.click(); }, 1200);
        }
      }
    }


function goBackToCourse() {
  const topic = "<%= topic %>";

  if (topic === "ai") {
    window.location.href = "/ai-intro";
  } else if (topic === "datascience") {
    window.location.href = "/ds-intro";
  } else if (topic === "webdev") {
    window.location.href = "/webdev-intro";
  } else {
    window.location.href = "/";
  }
}
// ── Player dropdown toggle ────────────────────────
function togglePlayerDropdown() {
  const dd = document.getElementById('player-dropdown');
  dd.classList.toggle('open');
}

// Close when clicking outside
document.addEventListener('click', (e) => {
  const profile = document.querySelector('.player-user-profile');
  if (profile && !profile.contains(e.target)) {
    document.getElementById('player-dropdown')?.classList.remove('open');
  }
});
  </script>

</body>
</html>
