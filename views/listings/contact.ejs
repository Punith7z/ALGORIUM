<% layout("/layouts/boilerplate.ejs" )%>
<section class="contact-premium">

<div class="contact-wrapper">

<div class="contact-header">
    <div class="con">
        <h1>Contact</h1>
<img src="/images/algo.png" class="login-logo">
    </div>

<p>
We would love to hear from you. Reach out to us for
questions, collaboration opportunities, or academic support.
</p>
</div>


<div class="contact-layout">

<!-- Left info card -->

<div class="contact-info-card">

<h3>Contact Information</h3>

<div class="contact-item">
<span>Email</span>
<p>algoriumhelo@gmail.com</p>
</div>

<div class="contact-item">
<span>Phone</span>
<p>+91 886181 5490</p>
</div>

<div class="contact-item">
<span>Location</span>
<p>MVJ College of Engineering, Bengaluru</p>
</div>

</div>



<!-- Contact form -->

<div class="contact-form-card">

<form id="contact-form">
  <div class="form-row">
    <input type="text" id="c-name" placeholder="Your Name" required>
  </div>
  <div class="form-row">
    <input type="email" id="c-email" placeholder="Your Email" required>
  </div>
  <div class="form-row">
    <textarea id="c-message" placeholder="Your Message" required></textarea>
  </div>
  <button class="contact-send" type="submit">
    Send Message
  </button>
</form>

</div>

</div>

</div>

</section>
<script>
    /* contact.js — paste before </body> in your contact EJS */

document.addEventListener('DOMContentLoaded', function () {

  // ── Inject dot grid ───────────────────────────────────────
  const section = document.querySelector('.contact-premium');
  if (section) {
    const dots = document.createElement('div');
    dots.classList.add('contact-dots');
    section.prepend(dots);
  }

  // ── Scroll reveal for cards and form rows ─────────────────
  const revealEls = document.querySelectorAll(
    '.contact-info-card, .contact-form-card, .form-row, .contact-send'
  );

  const observer = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        entry.target.classList.add('visible');
        observer.unobserve(entry.target);
      }
    });
  }, { threshold: 0.12 });

  revealEls.forEach(el => observer.observe(el));

  // ── Send button loading state ─────────────────────────────
  const form = document.querySelector('.contact-form-card form');
  const btn  = document.querySelector('.contact-send');

  if (form && btn) {
    form.addEventListener('submit', async function (e) {
      e.preventDefault();

      const btn     = document.querySelector('.contact-send');
      const name    = document.getElementById('c-name').value.trim();
      const email   = document.getElementById('c-email').value.trim();
      const message = document.getElementById('c-message').value.trim();

      if (!name || !email || !message) {
        btn.textContent = '⚠️ Fill all fields!';
        return;
      }

      btn.textContent = 'Sending...';
      btn.disabled = true;

      try {
        const res = await fetch('/contact', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ name, email, message })
        });

        const data = await res.json();

        if (data.success) {
          btn.textContent = '✓ Message Sent!';
          form.reset();
        } else {
          btn.textContent = '✗ Failed. Try Again';
          btn.disabled = false;
        }
      } catch (err) {
        console.error(err);
        btn.textContent = '✗ Error occurred';
        btn.disabled = false;
      }
    });
  }

  // ── Input focus label highlight ───────────────────────────
  document.querySelectorAll('.form-row input, .form-row textarea').forEach(el => {
    el.addEventListener('focus', () => {
      el.closest('.form-row').style.transform = 'translateY(-2px)';
    });
    el.addEventListener('blur', () => {
      el.closest('.form-row').style.transform = 'translateY(0)';
    });
  });

});

</script>