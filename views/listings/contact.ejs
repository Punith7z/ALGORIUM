
<% layout("/layouts/boilerplate.ejs" )%>
<section class="contact-premium">

<div class="contact-wrapper">

<div class="contact-header">
    <div class="con">
        <h1>Contact</h1>
<img src="/images/new.jpeg" class="login-logo">
    </div>

<p>
We would love to hear from you. Reach out to us for
questions, collaboration opportunities, or academic support.
</p>
</div>


<div class="contact-layout">

<!-- Left info card -->

<div class="contact-info-card">

<h3>Contact Information</h3>

<div class="contact-item">
<span>Email</span>
<p>algorium@mvjce.edu</p>
</div>

<div class="contact-item">
<span>Phone</span>
<p>+91 XXXXX XXXXX</p>
</div>

<div class="contact-item">
<span>Location</span>
<p>MVJ College of Engineering, Bengaluru</p>
</div>

</div>



<!-- Contact form -->

<div class="contact-form-card">

<form>

<div class="form-row">
<input type="text" placeholder="Your Name" required>
</div>

<div class="form-row">
<input type="email" placeholder="Your Email" required>
</div>

<div class="form-row">
<textarea placeholder="Your Message" required></textarea>
</div>

<button class="contact-send">
Send Message
</button>

</form>

</div>

</div>

</div>

</section>