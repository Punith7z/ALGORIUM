<script>

  // ── FAQ Toggle ────────────────────────────────────────────
  function toggleFaq(btn) {
    const item   = btn.closest('.ai-faq-item');
    const answer = item.querySelector('.ai-faq-a');
    const icon   = btn.querySelector('.ai-faq-icon');
    const isOpen = item.classList.contains('open');

    document.querySelectorAll('.ai-faq-item.open').forEach(el => {
      el.classList.remove('open');
      el.querySelector('.ai-faq-a').style.maxHeight = '0';
      el.querySelector('.ai-faq-icon').textContent  = '+';
    });

    if (!isOpen) {
      item.classList.add('open');
      answer.style.maxHeight = answer.scrollHeight + 'px';
      icon.textContent       = '−';
    }
  }

  // ── Scroll Reveal ─────────────────────────────────────────
  document.addEventListener('DOMContentLoaded', function () {
    const revealEls = document.querySelectorAll(
      '.ai-module-card, .ai-outcome-item, .ai-company-card, .ai-faq-item, .ai-section-header'
    );

    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          entry.target.classList.add('ai-visible');
          observer.unobserve(entry.target);
        }
      });
    }, { threshold: 0.1 });

    revealEls.forEach((el, i) => {
      el.style.transitionDelay = (i % 4) * 0.1 + 's';
      observer.observe(el);
    });

    // ── Hide scroll arrow once user scrolls ──────────────────
    const tease = document.querySelector('.scroll-tease');
    window.addEventListener('scroll', () => {
      if (window.scrollY > 80) {
        tease.style.opacity   = '0';
        tease.style.transform = 'translateY(10px)';
      } else {
        tease.style.opacity   = '1';
        tease.style.transform = 'translateY(0)';
      }
    }, { passive: true });
  });
</script>

