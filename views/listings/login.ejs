<% layout("/layouts/boilerplate.ejs" )%>


<section class="login-section">

<div class="login-card">
<img src="/images/new.jpeg" class="login-logo">
<h2 class="login-title"><span class="gold-access">Access</span>
</h2>

<p class="login-subtitle">
Enter your academic details to continue learning.
</p>

<form>

<div class="input-group">
<label>Name</label>
<input type="text" placeholder="Enter your name" required>
</div>

<div class="input-group">
<label>College ID</label>
<input type="text" placeholder="Enter your college ID" required>
</div>

<div class="input-group">
<label>Branch</label>
<input type="text" placeholder="Enter your branch" required>
</div>

<div class="input-group">
<label>Semester</label>
<input type="number" placeholder="Semester (1-8)" required>
</div>

<button type="submit" class="login-btn">
Continue to Algorium
</button>

</form>

</div>

</section>