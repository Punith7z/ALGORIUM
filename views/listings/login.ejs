<% layout("/layouts/boilerplate.ejs" )%>


<section class="login-section">

<div class="login-card">
<img src="/images/new.jpeg" class="login-logo">
<h2 class="login-title"><span class="gold-access">Access</span>
</h2>

<p class="login-subtitle">
Enter your academic details to continue learning.
</p>

<form>

<div class="input-group">
<label>Name</label>
<input type="text" placeholder="Enter your name" required>
</div>

<div class="input-group">
<label>College ID</label>
<input type="text" placeholder="Enter your college ID" required>
</div>

<div class="input-group">
<label>Branch</label>
<input type="text" placeholder="Enter your branch" required>
</div>

<div class="input-group">
<label>Semester</label>
<input type="number" placeholder="Semester (1-8)" required>
</div>

<button type="submit" class="login-btn">
Continue to Algorium
</button>

</form>

</div>

</section>
<script>
    /* login.js — paste before </body> in your login EJS */

document.addEventListener('DOMContentLoaded', function () {

  // ── Inject dot grid layer ─────────────────────────────────
  const section = document.querySelector('.login-section');
  if (section) {
    const dots = document.createElement('div');
    dots.classList.add('login-dots');
    section.prepend(dots);
  }

  // ── Input focus — add active class to group ───────────────
  document.querySelectorAll('.input-group input').forEach(input => {
    input.addEventListener('focus', () => {
      input.closest('.input-group').classList.add('active');
    });
    input.addEventListener('blur', () => {
      input.closest('.input-group').classList.remove('active');
    });
  });

  // ── Submit button — loading state ─────────────────────────
  const form = document.querySelector('.login-card form');
  const btn  = document.querySelector('.login-btn');

  if (form && btn) {
    form.addEventListener('submit', function (e) {
      btn.textContent = 'Launching Algorium...';
      btn.style.opacity = '0.85';
      btn.style.cursor  = 'not-allowed';
      btn.style.animation = 'none';
      btn.style.background = 'linear-gradient(110deg, #FF8C00, #FF3D00)';
    });
  }

  // ── Semester input — clamp between 1 and 8 ───────────────
  const semInput = document.querySelector('input[type="number"]');
  if (semInput) {
    semInput.addEventListener('input', () => {
      if (semInput.value > 8) semInput.value = 8;
      if (semInput.value < 1 && semInput.value !== '') semInput.value = 1;
    });
  }

});
</script>